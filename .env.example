# Mock mode flag — set to "false" to use real Clover/Twilio
MOCK_MODE=true

# Clover Ecommerce API (https://docs.clover.com/docs/ecommerce-api)
CLOVER_MERCHANT_ID=
CLOVER_API_TOKEN=
CLOVER_ENVIRONMENT=production

# Used to build the Clover redirect-back URL. Falls back to request host.
NEXT_PUBLIC_SITE_URL=https://cafedelightco.com

# Resend email (https://resend.com)
# Used for order confirmation receipts. Must be a verified sender on Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@cafedelightco.com

# Review prompt
# Email address that receives low-star (1-4) customer feedback.
FEEDBACK_EMAIL=cafedelightco@gmail.com
# Direct "Write a review" URL for the 5-star path. Get this from your
# Google Business Profile dashboard once claimed (search for "review link").
GOOGLE_REVIEW_URL=

# Google Analytics 4 measurement ID (public — exposed to the browser).
# Defaults to the Café Delight production ID; override here for staging.
NEXT_PUBLIC_GA_ID=G-ZY8TP9QDJM

# Clerk auth (auto-provisioned by Vercel Marketplace)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Business config
BUSINESS_NAME="Café Delight"
BUSINESS_ADDRESS="9395 Crown Crest Blvd, Parker, CO 80138"
BUSINESS_PHONE=""
PICKUP_ETA_MINUTES=5

# Sales tax rate as a decimal (0.08 = 8%). Must match the rate
# configured in Clover or orders will be rejected.
TAX_RATE=0.08

# Set to "true" to accept orders 24/7 regardless of business hours.
# Use during testing; remove or set to "false" before launch.
BYPASS_HOURS=false
